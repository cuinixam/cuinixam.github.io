<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Alexandru Maxiniuc</title>
<link rel="icon" href="_static/bio-photo-circle.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="_landing/landing.css" />
</head>
<body>

<nav>
  <a class="brand" href="index.html">maxiniuc.com</a>
  <ul>
    <li><a href="#projects">projects</a></li>
    <li><a href="#teaching">teaching</a></li>
    <li><a href="#writing">writing</a></li>
    <li><a href="#about">about</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid">
    <div class="hero-text">
      <div class="eyebrow"></div>
      <h1>Alexandru<br/><span class="accent">Maxiniuc</span>.</h1>
      <div class="tagline">I'm not just another engineer.<span class="cursor"></span></div>
      <div class="meta">
        <span>Software product lines</span>
        <span>Build systems</span>
        <span>Architecture</span>
      </div>
    </div>
    <pre class="hero-art" aria-label="Portrait of Alexandru Maxiniuc">{% include "portrait.txt" %}</pre>
  </div>
  <div class="scroll-hint">SCROLL ↓</div>
</section>

<!-- HORIZONTAL CAROUSEL: PROJECTS -->
<section class="carousel-wrap" id="projects" style="height: {{ (projects|length) * 100 }}vh;">
  <div class="carousel-pin">
    <div class="carousel-head">
      <h2>Some things I am <span class="accent">working on.</span></h2>
      <div class="see-all-group">
        <a class="see-all" href="https://github.com/cuinixam/" target="_blank" rel="noopener">all projects</a>
        <div class="carousel-progress">
          <span id="panelLabel">01 / {{ "%02d" | format(projects|length) }}</span>
          <div class="bar"><div class="fill" id="carouselFill"></div></div>
        </div>
      </div>
    </div>
    <div class="carousel-track" id="carouselTrack">
      {%- for project in projects %}
      <div class="panel">
        <div class="panel-text">
          <div class="tag">// {{ project.year_range }}</div>
          <h3>{{ project.name }}</h3>
          <div class="subtitle">{{ project.subtitle }}</div>
          <p>{{ project.description }}</p>
          <div class="links">
            <a href="{{ project.github_url }}" target="_blank" rel="noopener">{{ project.github_label }}</a>
          </div>
        </div>
        <div class="panel-code">
          <div class="titlebar">
            <div class="dot"></div><div class="dot"></div><div class="dot"></div>
            <div class="path">{{ project.code_title }}</div>
          </div>
<pre>{{ project.code_html | safe }}</pre>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- TEACHING (one nav anchor, three original sub-sections inside) -->
<section id="teaching">
  <div class="talks">
    <div class="section-head">
      <h2>Selected <span class="accent">talks.</span></h2>
    </div>
    <div class="talks-grid">
      {%- for talk in talks %}
      <a class="talk" href="{{ talk.link }}">
        <div class="num">{{ "%02d" | format(loop.index) }}</div>
        <h3>{{ talk.title }}</h3>
        <p>{{ talk.description }}</p>
      </a>
      {%- endfor %}
    </div>
  </div>

  <div class="talks">
    <div class="section-head">
      <h2>Interactive <span class="accent">demos.</span></h2>
    </div>
    <div class="talks-grid">
      {%- for demo in demos %}
      <a class="talk" href="{{ demo.link }}">
        <div class="num">{{ "%02d" | format(loop.index) }}</div>
        <h3>{{ demo.title }}</h3>
        <p>{{ demo.description }}</p>
      </a>
      {%- endfor %}
    </div>
  </div>

  <div class="talks">
    <div class="section-head">
      <h2>Notebooks for <span class="accent">learning.</span></h2>
    </div>
    <div class="talks-grid">
      {%- for notebook in notebooks %}
      <a class="talk" href="{{ notebook.link }}">
        <div class="num">{{ "%02d" | format(loop.index) }}</div>
        <h3>{{ notebook.title }}</h3>
        <p>{{ notebook.description }}</p>
      </a>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- WRITING -->
<section class="writing" id="writing">
  <div class="section-head">
    <h2>Recent <span class="accent">writing.</span></h2>
    <a class="see-all" href="blogs.html">all posts</a>
  </div>
  <div class="writing-list">
    {%- for post in writing %}
    <a class="writing-row" href="{{ post.url }}">
      <div class="date">{{ post.date_label }}</div>
      <div class="title">{{ post.title }}</div>
      <div class="tag">// {{ post.category }}</div>
    </a>
    {%- endfor %}
  </div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="section-head">
    <h2>About <span class="accent">me.</span></h2>
    <div class="see-all-group">
      <a class="see-all" href="about.html">full about</a>
      <a class="see-all" href="about.html#timeline">timeline</a>
    </div>
  </div>
  <p>Currently I develop software applications for the automotive industry and I help individuals and teams to improve their software development skills.</p>
  <p class="muted">I am interested in engineering software product lines, software architecture and build systems.</p>
</section>

<footer>
  <div>© <span id="year"></span> Alexandru Maxiniuc</div>
  <div>
    <a href="https://github.com/cuinixam/" target="_blank" rel="noopener">github</a>
    <a href="https://www.linkedin.com/in/alexandru-maxiniuc-53604612" target="_blank" rel="noopener">linkedin</a>
    <a href="blogs/atom.xml">rss</a>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // ----- Horizontal carousel -----
  (function () {
    const wrap = document.querySelector('.carousel-wrap');
    const track = document.getElementById('carouselTrack');
    const fill = document.getElementById('carouselFill');
    const label = document.getElementById('panelLabel');
    if (!wrap || !track) return;
    const panels = track.children.length;

    function onScroll() {
      const rect = wrap.getBoundingClientRect();
      const total = wrap.offsetHeight - window.innerHeight;
      const progress = Math.min(1, Math.max(0, -rect.top / total));
      const travel = (panels - 1) * 100;
      track.style.transform = `translateX(-${progress * travel}vw)`;
      fill.style.width = (progress * 100) + '%';
      const idx = Math.min(panels - 1, Math.floor(progress * panels + 0.0001));
      label.textContent = String(idx + 1).padStart(2, '0') + ' / ' + String(panels).padStart(2, '0');
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();

  // ----- Card reveal (talks + teaching) -----
  (function () {
    const cards = document.querySelectorAll('.talk, .teach');
    const io = new IntersectionObserver((items) => {
      items.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    cards.forEach((c, i) => {
      c.style.transitionDelay = ((i % 3) * 90) + 'ms';
      io.observe(c);
    });
  })();
</script>

</body>
</html>
